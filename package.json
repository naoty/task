{
  "name": "task",
  "version": "0.1.0",
  "bin": {
    "task": "./dist/index.mjs"
  },
  "type": "module",
  "scripts": {
    "build:css": "bunx @tailwindcss/cli -i src/ui/globals.css -o dist/ui/globals.css --minify",
    "build:ui": "bun build src/ui/main.tsx --outdir dist/ui/ --target browser",
    "build:bin": "bun build --compile src/cli/index.ts --outfile build/task",
    "build": "bun run build:css && bun run build:ui && cp src/ui/index.html dist/ui/index.html && bun run build:bin",
    "dev:css": "bunx @tailwindcss/cli -i src/ui/globals.css -o dist/ui/globals.css --watch",
    "test": "bun test",
    "check": "biome check",
    "fix": "biome check --write"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.168.7",
    "cac": "^6.7.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@tailwindcss/cli": "^4.2.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.2.2"
  },
  "packageManager": "bun"
}
