{
  "name": "task",
  "version": "0.3.1",
  "bin": {
    "task": "./dist/index.mjs"
  },
  "type": "module",
  "scripts": {
    "build:ui": "vite build",
    "build:bin": "bun build --compile src/cli/index.ts --outfile build/task && bun build --compile --target=bun-linux-x64 src/cli/index.ts --outfile build/task-linux-x64 && bun build --compile --target=bun-linux-arm64 src/cli/index.ts --outfile build/task-linux-arm64 && bun build --compile --target=bun-darwin-x64 src/cli/index.ts --outfile build/task-darwin-x64 && bun build --compile --target=bun-darwin-arm64 src/cli/index.ts --outfile build/task-darwin-arm64",
    "build": "bun run build:ui && bun run build:bin",
    "dev": "vite",
    "test": "bun test",
    "check": "biome check",
    "fix": "biome check --write"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@tanstack/react-router": "^1.168.7",
    "@tiptap/extension-code-block-lowlight": "^3.22.1",
    "@tiptap/extension-link": "^3.22.2",
    "@tiptap/extension-table": "^3.22.2",
    "@tiptap/extension-table-cell": "^3.22.2",
    "@tiptap/extension-table-header": "^3.22.2",
    "@tiptap/extension-table-row": "^3.22.2",
    "@tiptap/markdown": "^3.22.1",
    "@tiptap/react": "^3.22.1",
    "@tiptap/starter-kit": "^3.22.1",
    "@xyflow/react": "^12.10.2",
    "cac": "^6.7.14",
    "lowlight": "^3.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@happy-dom/global-registrator": "^20.8.9",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/dagre": "^0.7.54",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.3"
  },
  "packageManager": "bun"
}
